# Social Backend Environment Variables

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost/stellar_social

# Server Configuration
HOST=0.0.0.0
PORT=8081

# Logging
RUST_LOG=info,actix_web=debug,sqlx=warn

# JWT Configuration (for production auth)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRY_HOURS=24

# Encryption (optional server-side utilities)
ENCRYPTION_SERVICE_ENABLED=false
